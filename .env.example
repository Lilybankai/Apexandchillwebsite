# ============================================================================
# Apex & Chill Racing — environment configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values you have. EVERY value
# is optional: any integration without credentials automatically falls back to
# bundled sample data, so the site runs out-of-the-box. Supply keys to switch
# an integration from "sample" to live. No code changes are needed.
# ============================================================================

# ----------------------------------------------------------------------------
# SimGrid  →  LMU league standings + next race
#   Where to find these: SimGrid account → API / integrations settings.
#   championship id: the SimGrid championship for the current LMU season.
# ----------------------------------------------------------------------------
SIMGRID_API_BASE_URL=https://www.simgrid.com/api
SIMGRID_API_TOKEN=
SIMGRID_LMU_CHAMPIONSHIP_ID=

# ----------------------------------------------------------------------------
# Sim League Pro  →  GT7 league standings + next race
#   league id: the Sim League Pro league for the current GT7 season.
#   season id (optional): pin a specific season; defaults to the active one.
# ----------------------------------------------------------------------------
SIMLEAGUEPRO_API_BASE_URL=https://api.simleague.pro
SIMLEAGUEPRO_API_KEY=
SIMLEAGUEPRO_GT7_LEAGUE_ID=
SIMLEAGUEPRO_GT7_SEASON_ID=

# ----------------------------------------------------------------------------
# YouTube Data API v3  →  replays gallery
#   api key: Google Cloud console → APIs & Services → Credentials. This is the
#     ONLY value you must supply — channel + playlist default to Apex & Chill's.
#   channel id: defaults to UCu7lyaGuo3sY2wWZo42-LVw (Apex & Chill).
#   playlist id: defaults to the curated replays playlist
#     PLHRp_wnmBUBcaFRSJwhWdgNvyzzUobCu0. Override to pull a different playlist.
# ----------------------------------------------------------------------------
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=UCu7lyaGuo3sY2wWZo42-LVw
YOUTUBE_UPLOADS_PLAYLIST_ID=PLHRp_wnmBUBcaFRSJwhWdgNvyzzUobCu0

# ----------------------------------------------------------------------------
# Supabase  →  join submissions + optional cached standings
#   Project settings → API. The anon key is public (safe in the browser); the
#   service-role key is SERVER-ONLY — never expose it to the client.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# Merch & payments  →  merch store (owned by the merch integration)
#   Documented here so all keys live in one place. Tapstitch + Printful are the
#   print-on-demand providers; Stripe handles checkout. Absent keys fall back to
#   a sample product catalog.
# ----------------------------------------------------------------------------
TAPSTITCH_API_KEY=
TAPSTITCH_STORE_ID=
PRINTFUL_API_KEY=
PRINTFUL_STORE_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
