# ============================================================================
# Apex & Chill Racing — environment template
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values THERE.
# `.env.local` is gitignored — NEVER put real secrets in this .env.example file
# (it is committed to the repository).
# Every integration degrades to bundled sample data when its keys are absent,
# so the site still builds and renders without any of these set.
# ============================================================================

# ----------------------------------------------------------------------------
# SimGrid (GridOS)  →  Le Mans Ultimate standings, schedule + next race
# API token: thesimgrid.com → "My Communities" ▸ Developers ▸ API token.
# ----------------------------------------------------------------------------
SIMGRID_API_BASE_URL=https://www.thesimgrid.com/api/v1
SIMGRID_API_KEY=
# The numeric id in the championship URL, e.g. thesimgrid.com/championships/24215
SIMGRID_LMU_CHAMPIONSHIP_ID=
# Add another SimGrid championship (e.g. the Thursday league) by setting its id
# here and registering it in lib/leagues.ts. See README ▸ "Adding a SimGrid league".
SIMGRID_THURSDAY_CHAMPIONSHIP_ID=

# ----------------------------------------------------------------------------
# Sim League Pro  →  GT7 league standings, schedule + next race
# Public API (no key needed). The league id is the UUID in the league URL, e.g.
# simleaguepro.com/api/v1/leagues/<UUID>.json
# ----------------------------------------------------------------------------
SIMLEAGUEPRO_API_BASE_URL=https://simleaguepro.com/api/v1
SIMLEAGUEPRO_API_KEY=
SIMLEAGUEPRO_GT7_LEAGUE_ID=
SIMLEAGUEPRO_GT7_SEASON_ID=

# ----------------------------------------------------------------------------
# YouTube Data API v3  →  replays gallery
# ----------------------------------------------------------------------------
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=UCu7lyaGuo3sY2wWZo42-LVw
# Single playlist (bare id or a pasted playlist/share URL — the "list=" id is
# extracted automatically). Blank = the channel's uploads.
YOUTUBE_UPLOADS_PLAYLIST_ID=
# Multiple playlists as separate Replays-page sections. Comma-separated; each is
# "Heading | url-or-id" (heading optional). Supersedes the single playlist above.
# YOUTUBE_PLAYLISTS=GT7 League | PLaaaaaaaa, LMU League | PLbbbbbbbb
YOUTUBE_PLAYLISTS=

# ----------------------------------------------------------------------------
# Supabase  →  join submissions + cached data
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# Merch — print-on-demand providers + Stripe checkout
# ----------------------------------------------------------------------------
# Tapstitch has NO product/order API, so its products are maintained by hand in
# lib/merch/tapstitch.ts and fulfilled manually (order emailed + shown in /admin).
# These vars are unused by the manual catalog and kept only for reference.
TAPSTITCH_API_KEY=
TAPSTITCH_STORE_ID=
# Printify DOES sync automatically (catalog + order fulfilment). Needs a Personal
# Access Token (Account → Connections) AND your numeric shop id (from
# GET https://api.printify.com/v1/shops.json). Both are required.
PRINTIFY_API_KEY=
PRINTIFY_SHOP_ID=
# Set to "true" to auto-confirm (send to production, charge & ship) Printify
# orders from the Stripe webhook. Leave unset/false to create orders you review
# and send to production yourself in the dashboard.
PRINTIFY_AUTO_CONFIRM=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ----------------------------------------------------------------------------
# Order notifications — Resend (emails you every completed order)
# Create an API key at resend.com; verify a sending domain for ORDER_EMAIL_FROM
# (until then Resend only delivers to your own account email from onboarding@resend.dev).
# ----------------------------------------------------------------------------
RESEND_API_KEY=
# Where order emails are sent (your inbox).
ORDER_NOTIFICATION_EMAIL=
# Verified From address, e.g. "Apex & Chill Orders <orders@apexandchill.com>".
ORDER_EMAIL_FROM=

# ----------------------------------------------------------------------------
# Admin dashboard  →  /admin  (single shared password gate)
# Set a strong password; the /admin orders dashboard is locked until you do.
# ----------------------------------------------------------------------------
ADMIN_PASSWORD=
